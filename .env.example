# ============================================================================
# 環境変数(仕様書 §13)
# このファイルをコピーして `.env.local` を作成し、各値を埋めること。
# `.env.local` は .gitignore で除外済み。
# ============================================================================

# ----------------------------------------------------------------------------
# Supabase
# ----------------------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# サーバー専用キー(クライアントから絶対に参照しない / 仕様書 §12.4)
SUPABASE_SERVICE_ROLE_KEY=

# ----------------------------------------------------------------------------
# 移行スクリプト用(仕様書 §6, §13)
# ----------------------------------------------------------------------------
MIGRATE_SOURCE_DIR=./csv
MIGRATE_ERROR_DIR=./errors

# ----------------------------------------------------------------------------
# Google Drive 定期取込(#1 / CLAUDE.md §5.10c) — サーバー専用
# サービスアカウントキー(JSON)をそのまま1行で設定する。
# 取込対象のファイル/フォルダを、このSAの client_email に「閲覧者」で共有すること。
# 例: GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account","client_email":"...","private_key":"-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n",...}
# ----------------------------------------------------------------------------
GOOGLE_SERVICE_ACCOUNT_JSON=
