{
  "name": "kawara-crm",
  "version": "0.1.0",
  "private": true,
  "description": "擬似Salesforce (ひらプロCRM) - 営業活動ログ管理システム",
  "scripts": {
    "dev": "next dev --turbo",
    "build": "next build",
    "start": "next start",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "db:types": "supabase gen types typescript --local > lib/supabase/types.ts",
    "db:migrate:new": "supabase migration new",
    "db:reset": "supabase db reset",
    "migrate:users": "tsx scripts/migrate/01_users.ts",
    "migrate:projects": "tsx scripts/migrate/02_projects.ts",
    "migrate:forms": "tsx scripts/migrate/03_forms.ts",
    "migrate:members": "tsx scripts/migrate/04_members.ts",
    "migrate:inquiries": "tsx scripts/migrate/05_inquiries.ts",
    "migrate:applications": "tsx scripts/migrate/06_applications.ts",
    "migrate:activities": "tsx scripts/migrate/07_activities.ts",
    "sample:csv": "tsx scripts/sample/extract.ts",
    "seed:sales": "tsx scripts/seed/sales_users.ts",
    "seed:sales:inactive": "tsx scripts/seed/sales_users_inactive.ts",
    "seed:acquirers": "tsx scripts/seed/map_acquirers.ts",
    "seed:fields": "tsx scripts/seed/sync_csv_fields.ts",
    "import:verify": "tsx scripts/import/00_verify_mapping.ts",
    "import:projects": "tsx scripts/import/01_projects.ts",
    "import:members": "tsx scripts/import/02_members.ts",
    "import:inquiries": "tsx scripts/import/03_inquiries.ts",
    "import:applications": "tsx scripts/import/04_applications.ts"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@hookform/resolvers": "^3.9.1",
    "@supabase/ssr": "^0.5.2",
    "@supabase/supabase-js": "^2.46.1",
    "@tanstack/react-table": "^8.20.5",
    "@types/ws": "^8.18.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "lucide-react": "^0.460.0",
    "next": "15.0.7",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-hook-form": "^7.53.2",
    "react-is": "^19.2.6",
    "recharts": "^3.8.1",
    "tailwind-merge": "^2.5.4",
    "tailwindcss-animate": "^1.0.7",
    "ws": "^8.20.0",
    "xlsx": "^0.18.5",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@playwright/test": "^1.49.0",
    "@types/node": "^22.9.1",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "autoprefixer": "^10.4.20",
    "postcss": "^8.4.49",
    "supabase": "^1.219.2",
    "tailwindcss": "^3.4.15",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vite-tsconfig-paths": "^6.1.1",
    "vitest": "^2.1.5"
  },
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=10.0.0"
  }
}
