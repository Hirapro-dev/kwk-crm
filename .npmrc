# プロジェクト固有の npm 設定
# 参照: https://docs.npmjs.com/cli/v10/configuring-npm/npmrc

# React 19 等の peer dependency 競合を回避(Next.js 15 + React 19の組み合わせで必要)
legacy-peer-deps=true

# ユーザーグローバルの globalconfig / prefix を無効化(nvm との互換性確保)
# プロジェクト内で安定して `npm` が動くようにする
globalconfig=
prefix=

# 保存時は package.json を厳密バージョンではなく caret(^)で
save-prefix="^"

# 監査ログは install を遅くするのでデフォルト無効化(必要時 `npm audit` を別途実行)
audit=false
fund=false
