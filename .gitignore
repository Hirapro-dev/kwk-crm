# 移行データ(個人情報含む / 仕様書 §12.4) — csv/ errors/ 配下は .gitkeep 以外すべて除外
csv/*
errors/*
!csv/.gitkeep
!errors/.gitkeep

# 作業用バックアップ・一時ファイル(誤コミット防止)
*.bak
*.attempt*
*.tmp.*

